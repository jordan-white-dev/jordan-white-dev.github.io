{
  "name": "sudoku-app",
  "version": "1.0.0",
  "private": true,
  "author": "jordanwhite",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "type:check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest --coverage run",
    "check": "pnpm biome:check && pnpm type:check && pnpm test",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-router": "^1.167.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-timer-hook": "^4.0.5",
    "sudoku": "^0.0.3",
    "super-expressive": "^2.0.0",
    "use-session-storage-state": "^19.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.14",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "knip": "^5.88.0",
    "typescript": "5.9.3",
    "vite": "npm:rolldown-vite@7.1.20",
    "vite-plugin-checker": "^0.12.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
