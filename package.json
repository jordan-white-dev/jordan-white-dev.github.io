{
  "name": "sudoku",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://jordan-white-dev.vercel.app/",
  "author": "jordanwhite",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "neverBuiltDependencies": []
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest --coverage run",
    "check:turbo": "pnpm turbo biome:check type:check test",
    "knip": "knip",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "push-release": "git push --follow-tags origin main",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-router": "^1.167.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-timer-hook": "^4.0.5",
    "sudoku": "^0.0.3",
    "super-expressive": "^2.0.0",
    "use-session-storage-state": "^19.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/react-devtools": "^0.8.6",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.13",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "knip": "^5.88.0",
    "turbo": "^2.8.18",
    "typescript": "5.9.3",
    "vite": "npm:rolldown-vite@7.1.20",
    "vite-plugin-checker": "^0.11.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  }
}
