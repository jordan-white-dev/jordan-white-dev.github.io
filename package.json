{
  "name": "sudoku",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://jordan-white-dev.github.io",
  "author": "jordanwhite",
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "neverBuiltDependencies": []
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "biome:check": "biome check --no-errors-on-unmatched --error-on-warnings",
    "biome:fix": "pnpm biome:check --write",
    "biome:ci": "biome ci",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest --coverage run",
    "check:turbo": "pnpm turbo biome:check type:check test",
    "knip": "knip",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-devtools": "^0.8.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-timer-hook": "^4.0.5",
    "sudoku": "^0.0.3",
    "super-expressive": "^2.0.0",
    "use-local-storage-state": "^19.5.0",
    "use-session-storage-state": "^19.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@chakra-ui/cli": "^3.34.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/types": "^20.4.3",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/router-plugin": "^1.166.7",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "commit-and-tag-version": "^12.6.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "rollup-plugin-visualizer": "^6.0.11",
    "turbo": "^2.8.16",
    "typescript": "5.9.3",
    "vite": "npm:rolldown-vite@7.1.20",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
